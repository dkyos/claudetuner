{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.25.4",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "permissions": [
    "alarms",
    "storage",
    "scripting",
    "notifications",
    "cookies",
    "idle",
    "sidePanel",
    "webRequest"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://claudetuner.com/*"
  ],
  "optional_host_permissions": [
    "https://chatgpt.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "__MSG_appDefaultTitle__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://claudetuner.com/*"
    ]
  },
  "content_scripts": [{
    "matches": ["https://claude.ai/*"],
    "css": ["sidebar-usage.css", "input-usage.css"],
    "js": ["sidebar-usage.js", "input-usage.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": ["icons/icon48.png"],
    "matches": [
      "https://claudetuner.com/*"
    ]
  }, {
    "resources": ["icons/icon16.png"],
    "matches": ["https://claude.ai/*"]
  }]
}
